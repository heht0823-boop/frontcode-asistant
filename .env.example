# ============================================
# FrontCode Assistant - 环境变量配置
# ============================================
# 使用方式：复制此文件为 .env，填入你的密钥
# cp .env.example .env
# ============================================

# OpenAI 兼容 API 配置（必填）
OPENAI_API_KEY=sk-你的密钥在这里
OPENAI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.6-plus

# ============================================
# 注意：
# 1. .env 文件已加入 .gitignore，不会提交到 Git
# 2. 永远不要将密钥硬编码到代码或 settings.json 中
# 3. 如果同时在 settings.json 和 .env 中配置了密钥，
#    .env 中的值会覆盖 settings.json 中的值
# ============================================
